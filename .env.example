# Railway injects DATABASE_URL automatically after adding PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/railway

# ChromaDB persistent path (Railway volume)
CHROMA_PATH=/data/chromadb

# MCP secret key (ตั้งค่าเองได้เลย)
MCP_SECRET=your-secret-key-here

# AAOS System Level
AAOS_LEVEL=5.5

# Optional: Notion token (ถ้าต้องการ sync Notion)
# NOTION_TOKEN=secret_xxx
