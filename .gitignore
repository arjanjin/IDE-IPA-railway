# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Railway / Docker / Deployment artifacts
# -----------------------------------------------------------------------------
.railway/
.docker/
docker-compose.override.yml
.dockerignore.bak

# -----------------------------------------------------------------------------
