# =============================================================================
# .gitignore — IDE-IPA-railway (ALIVE Framework V2.0 MCP Server)
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
env/
ENV/
.venv/
.env.venv/
env.bak/
venv.bak/

# -----------------------------------------------------------------------------
# Environment variables and secrets — CRITICAL FOR ZENODO ARCHIVAL
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.env
secrets.json
credentials.json
service-account*.json
*.pem
*.key
*.crt
*.p12
*.pfx
.secrets/
config/secrets.yaml

# Common API key file patterns
**/api_key*
**/api-key*
**/*api_key*.txt
*.token
.netrc

# -----------------------------------------------------------------------------
# Databases — SQLite, PostgreSQL dumps, ChromaDB local data
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.dump
*.sql.gz
*.bak
data/
chroma_data/
chromadb_data/
.chroma/
chroma.sqlite3

# -----------------------------------------------------------------------------
# Backups (runtime-generated via /backup/shared_kb endpoint)
# -----------------------------------------------------------------------------
backups/
backup*.json
backup*.zip
restored_check*.json
shared_kb_backup_*.json

# -----------------------------------------------------------------------------
# ML / Embedding model caches
# -----------------------------------------------------------------------------
.cache/
.huggingface/
sentence_transformers_cache/
transformers_cache/
torch_cache/
~/.cache/torch/
models_cache/

# -----------------------------------------------------------------------------
# Logs and runtime artifacts
# -----------------------------------------------------------------------------
*.log
logs/
log/
*.log.*
runtime_logs/
nohup.out

# -----------------------------------------------------------------------------
# Testing and coverage
# -----------------------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.py,cover
test-results/
test_output/

# -----------------------------------------------------------------------------
# Type checkers and linters
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
